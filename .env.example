# Reference for Vercel environment variable names — set values in Vercel Production, not locally.
# See docs/ENV.md for full descriptions.

# ── Supabase (required) ──────────────────────────────────────────────────────
# Project Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Project Settings → API → anon / public key (legacy JWT or new publishable key)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Alternative to ANON_KEY if using Supabase's newer publishable key format
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Service role key — server-only, never expose to browser (cron bypasses RLS)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Anthropic (required for chat) ────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Plaid Production (required for real Chase / budget / round-ups) ──────────
PLAID_CLIENT_ID=your_plaid_client_id
PLAID_SECRET=your_plaid_production_secret
PLAID_ENV=production

# ── Coinbase CDP (required for Theo Fund buys) ───────────────────────────────
# Portal → API Keys → Create key with view + trade, ECDSA ES256
COINBASE_API_KEY_NAME=organizations/ORG_ID/apiKeys/KEY_ID
# Paste PEM private key; use \n for newlines in Vercel env values:
# COINBASE_API_PRIVATE_KEY="-----BEGIN EC PRIVATE KEY-----\nMHcCAQEE...\n-----END EC PRIVATE KEY-----\n"
COINBASE_API_PRIVATE_KEY=

# ── TRMNL (optional — reminders + daily budget push) ─────────────────────────
TRMNL_WEBHOOK_URL=https://trmnl.com/api/custom_plugins/YOUR_PLUGIN_ID/webhook

# ── Budget (optional — defaults to 6000 if unset) ────────────────────────────
# Monthly household budget in USD (Budget tab, chat agent, TRMNL cron)
NEXT_PUBLIC_MONTH_BUDGET=6000

# ── Vercel cron (required for budget-push cron) ─────────────────────────────
# Generate: openssl rand -hex 32
# Vercel Production cron sends: Authorization: Bearer <CRON_SECRET>
# Manual test: curl -H "Authorization: Bearer $CRON_SECRET" https://YOUR_VERCEL_DOMAIN/api/cron/budget-push
CRON_SECRET=generate_a_long_random_string
